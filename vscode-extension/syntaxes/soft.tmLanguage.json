{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Soft",
  "scopeName": "source.soft",
  "patterns": [
    { "include": "#code-block" },
    { "include": "#template-block" },
    { "include": "#style-block" },
    { "include": "#decorators" },
    { "include": "#comments" }
  ],
  "repository": {
    "decorators": {
      "patterns": [
        {
          "name": "meta.decorator.soft",
          "match": "@(Page|Service|Route|Template|Code|Style|importComponent|State|Computed|Watch|Prop|custom)\\b",
          "captures": {
            "1": { "name": "storage.type.decorator.soft" }
          }
        }
      ]
    },
    "template-block": {
      "begin": "@Template(\\s*\\{)?",
      "end": "(?=@(Code|Style)|^\\s*\\}\\s*$)",
      "patterns": [
        { "include": "#html-tags" },
        { "include": "#directives" },
        { "include": "#interpolation" },
        { "include": "#attributes" }
      ]
    },
    "code-block": {
      "begin": "@Code(\\s*\\{)?",
      "end": "(?=@(Template|Style)|^\\s*\\}\\s*$|\\z)",
      "contentName": "meta.embedded.block.typescript",
      "patterns": [
        { "include": "source.ts" }
      ]
    },
    "style-block": {
      "begin": "@Style(\\(scoped\\))?(\\s*\\{)?",
      "end": "(?=@(Template|Code)|^\\s*\\}\\s*$|\\z)",
      "contentName": "meta.embedded.block.css",
      "patterns": [
        { "include": "source.css" }
      ]
    },
    "html-tags": {
      "patterns": [
        {
          "name": "meta.tag.soft",
          "begin": "</?([a-zA-Z][a-zA-Z0-9]*)",
          "end": "/?>",
          "beginCaptures": {
            "1": { "name": "entity.name.tag.soft" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.tag.end.soft" }
          },
          "patterns": [
            { "include": "#attributes" }
          ]
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.soft",
          "match": "@(if|else|foreach|switch|case|default|slot|Navigate)\\b"
        },
        {
          "name": "meta.directive.block.soft",
          "begin": "@(if|foreach|switch|slot|Navigate)\\s*\\(",
          "end": "\\)",
          "patterns": [
            { "include": "source.ts#expression" }
          ]
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.soft",
          "match": "@(bind|click|submit|show|disabled|ref|key|class|style|soft|x|ui|app):[a-zA-Z-]+"
        },
        {
          "name": "entity.other.attribute-name.html",
          "match": "[a-zA-Z-]+"
        },
        {
          "match": "(=\\s*\")([^\"]*)(\")",
          "captures": {
            "1": { "name": "punctuation.definition.string.begin.soft" },
            "2": { "name": "string.quoted.double.soft" },
            "3": { "name": "punctuation.definition.string.end.soft" }
          }
        }
      ]
    },
    "interpolation": {
      "name": "meta.interpolation.soft",
      "begin": "@\\(",
      "end": "\\)",
      "patterns": [
        { "include": "source.ts#expression" }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.soft",
          "match": "//.*$"
        },
        {
          "name": "comment.block.soft",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    }
  }
}
